{
  "name": "gemstack",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "GemStack: a collection of high-quality, framework-agnostic tools. Home of @gemstack/ai-sdk.",
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "build": "turbo run build bundle:dashboard",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "test": "turbo run test",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "turbo run build bundle:dashboard --filter=./packages/* && changeset publish",
    "========= Website": "",
    "// Develop website https://the-framework.ai locally": "",
    "website": "cd packages/the-framework.ai/ && pnpm run dev",
    "// Build website for production": "",
    "website:build": "cd packages/the-framework.ai/ && pnpm run build",
    "// Test website (CI)": "",
    "website:test": "cd packages/the-framework.ai/ && echo 'no tests yet'"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "turbo": "^2.9.16",
    "typescript": "^5.4.0"
  }
}

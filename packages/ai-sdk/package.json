{
  "name": "@gemstack/ai-sdk",
  "version": "0.6.1",
  "description": "AI engine: providers, agents, tools, streaming, middleware. The first GemStack package.",
  "keywords": [
    "ai",
    "llm",
    "agent",
    "agents",
    "ai-agents",
    "tools",
    "tool-calling",
    "streaming",
    "computer-use",
    "eval",
    "structured-output",
    "anthropic",
    "claude",
    "openai",
    "gpt",
    "gemini",
    "bedrock",
    "gemstack"
  ],
  "license": "MIT",
  "homepage": "https://github.com/gemstack-land/the-framework/tree/main/packages/ai-sdk#readme",
  "bugs": {
    "url": "https://github.com/gemstack-land/the-framework/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gemstack-land/the-framework",
    "directory": "packages/ai-sdk"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "files": [
    "dist",
    "boost"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./node": {
      "import": "./dist/node/index.js",
      "types": "./dist/node/index.d.ts"
    },
    "./observers": {
      "import": "./dist/observers.js",
      "types": "./dist/observers.d.ts"
    },
    "./chat-mentions": {
      "import": "./dist/chat-mentions.js",
      "types": "./dist/chat-mentions.d.ts"
    },
    "./gateway": {
      "import": "./dist/gateway/index.js",
      "types": "./dist/gateway/index.d.ts"
    },
    "./eval": {
      "import": "./dist/eval/index.js",
      "types": "./dist/eval/index.d.ts"
    },
    "./computer-use": {
      "import": "./dist/computer-use/index.js",
      "types": "./dist/computer-use/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "tsc -p tsconfig.test.json && cd dist-test && node --test",
    "clean": "rm -rf dist dist-test"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "react": ">=19.2.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": ">=0.91.1",
    "@aws-sdk/client-bedrock-runtime": ">=3.600.0",
    "@google/genai": ">=1.0.0",
    "cohere-ai": ">=7.0.0",
    "openai": ">=4.70.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.0",
    "react": "^19.2.0",
    "typescript": "^5.4.0"
  },
  "author": "Suleiman Shahbari"
}
